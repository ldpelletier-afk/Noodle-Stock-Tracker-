# Nothing below is required to run the app. Core price/fundamentals data
# comes from yfinance (free, no key). Each key here just unlocks or improves
# one optional data source / feature; the app degrades gracefully without it.

# --- LLM backend -------------------------------------------------------
# Default is a local Ollama model (no key needed). Set this to route to a
# hosted provider instead (also settable from the Streamlit sidebar).
# LLM_BACKEND=ollama:llama3.2
NOODLE_UTILITY_MODEL=llama3.2

# --- Alerts --------------------------------------------------------------
# Required only if you run watcher.py for buy-target alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WATCHER_INTERVAL_SECONDS=300
WATCHER_ALERT_COOLDOWN_SECONDS=21600

# --- Real-time quotes (Alpaca IEX) ---------------------------------------
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- Macro / economic data ------------------------------------------------
FRED_API_KEY=
BEA_API_KEY=
BLS_API_KEY=
EIA_API_KEY=

# --- Fundamentals / financials ------------------------------------------
SIMFIN_API_KEY=
FMP_API_KEY=
ALPHA_VANTAGE_KEY=

# --- News / sentiment ------------------------------------------------------
NEWSAPI_KEY=
MARKETAUX_API_KEY=
FINNHUB_API_KEY=

# --- Legal / court filings ------------------------------------------------
COURTLISTENER_API_KEY=

# --- Storage overrides (rarely needed) ------------------------------------
# NOODLE_DB_FILE=portfolio.db
# NOODLE_LEGACY_JSON=portfolio.json
